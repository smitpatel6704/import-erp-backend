PORT=5001
APP_URL=http://localhost:3000
# FRONTEND_URL may be used instead of APP_URL.
AUTH_SECRET=replace-with-a-long-random-secret
DATABASE_URL=
DIRECT_URL=

# Gmail SMTP: use a Google App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM=NEXPORT ERP <your-account@gmail.com>
NOTIFICATION_EMAIL_TO=
NOTIFICATION_SCAN_INTERVAL_MS=21600000
# Optional: protect /api/notifications/run-reminders when called by an external cron.
CRON_SECRET=

# Maersk Developer Portal
# Vessels and Locations require only MAERSK_CONSUMER_KEY.
# Ocean Track & Trace additionally requires MAERSK_CONSUMER_SECRET and product approval.
MAERSK_API_BASE_URL=https://api.maersk.com
MAERSK_CONSUMER_KEY=
MAERSK_CONSUMER_SECRET=

# Optional fallback when official Ocean Track & Trace is not configured.
MAERSK_SCRAPER_FALLBACK=false
MAERSK_SCRAPER_HEADLESS=true
ENABLE_MAERSK_SCRAPER_ON_VERCEL=false
